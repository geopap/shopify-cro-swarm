# =============================================
# Shopify CRO Swarm — Environment Variables
# Copy to .env and fill in real values
# =============================================

# --- Google Analytics 4 ---
GA4_SERVICE_ACCOUNT_KEY=    # Path to service account JSON key file, or the JSON string itself
GA4_PROPERTY_ID=            # e.g., 123456789

# --- Google Search Console ---
GSC_SITE_URL=               # e.g., https://your-store.com (uses same service account as GA4)

# --- Shopify ---
SHOPIFY_STORE_URL=          # e.g., your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=       # Admin API access token from custom app

# --- Google Ads ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=    # e.g., 123-456-7890 (without dashes)

# --- Meta (Facebook/Instagram) Ads ---
META_ACCESS_TOKEN=          # System user token with ads_read permission
META_AD_ACCOUNT_ID=         # e.g., act_123456789

# --- Hotjar ---
HOTJAR_API_KEY=             # Business plan required
HOTJAR_SITE_ID=

# --- Slack ---
SLACK_WEBHOOK_URL=          # Incoming webhook for alerts channel

# --- GitHub (for Implementer PRs on theme repo) ---
GITHUB_THEME_REPO=         # e.g., owner/your-shopify-theme
GITHUB_THEME_TOKEN=        # PAT with repo write access

# --- Claude API (for GitHub Actions) ---
ANTHROPIC_API_KEY=
